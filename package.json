{
  "name": "plagifree",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "next dev",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "next build && tsc -p server/tsconfig.json",
    "start": "concurrently \"npm run start:web\" \"npm run start:server\"",
    "start:web": "next start",
    "start:server": "node server/dist/index.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "ioredis": "^5.8.1",
    "lucide-react": "^0.511.0",
    "mammoth": "^1.11.0",
    "mongodb": "^6.20.0",
    "multer": "^2.0.2",
    "next": "^15.5.3",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.17.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.6.0",
    "@types/pdfkit": "^0.17.3",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "eslint": "^9.38.0",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
